# API Key do Google Gemini
GEMINI_API_KEY=sua-chave-api-aqui

# Neon PostgreSQL Database URL
DATABASE_URL=postgresql://usuario:senha@host:porta/nome_do_banco

# Configuração do NextAuth.js
# NEXTAUTH_URL: A URL base do seu app (em dev: http://localhost:3000)
NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET: Uma string aleatória para criptografar sessões (pode gerar com `openssl rand -base64 32`)
NEXTAUTH_SECRET=sua-string-secreta-aleatoria-aqui